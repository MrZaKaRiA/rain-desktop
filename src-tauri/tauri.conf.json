{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAIN Desktop",
  "version": "0.1.0",
  "identifier": "com.mrzakaria.raindesktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "launcher",
        "title": "RAIN Desktop — Launcher",
        "width": 480,
        "height": 680,
        "minWidth": 400,
        "minHeight": 540,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Native launcher for your store",
    "longDescription": "Open your store/admin in a native desktop window and sign in (password + 2FA) inside, like a browser."
  }
}
